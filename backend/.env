# Server Configuration
NODE_ENV=development
PORT=3543
FRONTEND_URL=http://localhost:3002

# Number of proxy hops to trust for the real client IP (used by rate limiting).
# Use "1" behind a single reverse proxy / platform LB; set "false" when running
# with no proxy in front so clients can't spoof X-Forwarded-For.
TRUST_PROXY=1

# Database Configuration
# NOTE: the mongodb+srv:// URI below requires DNS TXT/SRV lookups, which this
# network blocks (queryTxt ETIMEOUT). The non-SRV URI lists the shard hosts
# directly and only needs A-record DNS, so it works here.
# SRV (original): mongodb+srv://root:david123@cluster0.fybwldj.mongodb.net/Virtual_Lab?retryWrites=true&w=majority
MONGODB_URI=mongodb://root:david123@ac-fjk9vie-shard-00-00.fybwldj.mongodb.net:27017,ac-fjk9vie-shard-00-01.fybwldj.mongodb.net:27017,ac-fjk9vie-shard-00-02.fybwldj.mongodb.net:27017/Virtual_Lab?ssl=true&replicaSet=atlas-9cauth-shard-0&authSource=admin&retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production